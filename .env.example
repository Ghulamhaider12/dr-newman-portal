# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://portal:portal@localhost:5432/dr_newman_portal?schema=public"

# ── NextAuth ──────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ── DigitalOcean Spaces (S3-compatible) ───────────────────
# Leave blank for local dev — the app falls back to local disk storage.
DO_SPACES_ENDPOINT=""
DO_SPACES_REGION="nyc3"
DO_SPACES_BUCKET=""
DO_SPACES_KEY=""
DO_SPACES_SECRET=""
DO_SPACES_CDN=""

# ── SendGrid (new-comment notifications) ──────────────────
# Leave blank to disable email (fail-soft).
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="portal@drnewman.example"
ADMIN_NOTIFY_EMAIL="admin@drnewman.example"

# ── Seed admin credentials ────────────────────────────────
SEED_ADMIN_USERNAME="anewman"
SEED_ADMIN_EMAIL="admin@drnewman.example"
SEED_ADMIN_PASSWORD="changeme123"
